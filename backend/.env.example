# ─────────────────────────────────────────────
# Botlixio — Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────

# ── Database ──────────────────────────────────
DATABASE_URL="postgresql+asyncpg://botlixio:botlixio@localhost:5432/botlixio"

# ── Auth ──────────────────────────────────────
# Generate: openssl rand -hex 32
SECRET_KEY=""
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── LLM API Keys (Admin-configured defaults) ──
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
GOOGLE_API_KEY=""

# ── Stripe ────────────────────────────────────
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PUBLISHABLE_KEY=""

# ── Email (Resend) ────────────────────────────
RESEND_API_KEY=""
EMAIL_FROM="noreply@botlixio.com"

# ── Redis ─────────────────────────────────────
REDIS_URL="redis://localhost:6379/0"

# ── Integration Encryption ────────────────────
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=""

# ── Frontend ──────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:8000"
NEXT_PUBLIC_APP_NAME="Botlixio"

# ── CORS ──────────────────────────────────────
CORS_ORIGINS="http://localhost:3000"

# ── App ───────────────────────────────────────
DEBUG=true
ENVIRONMENT="development"
