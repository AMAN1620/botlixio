# ─────────────────────────────────────────────────────────────
# Botlixio — Backend Environment Variables
# Copy to .env and fill in real values before running.
# ─────────────────────────────────────────────────────────────

# ── Database ────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://botlixio:password@localhost:5432/botlixio
POSTGRES_USER=botlixio
POSTGRES_PASSWORD=password
POSTGRES_DB=botlixio
POSTGRES_PORT=5432

# ── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Security ────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=change-me-in-production
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=change-me-in-production

# ── LLM Providers ───────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# ── Email (Resend) ───────────────────────────────────────────
RESEND_API_KEY=

# ── Billing (Stripe) ────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── WhatsApp Microservice ────────────────────────────────────
WHATSAPP_SERVICE_URL=http://localhost:3001
INTERNAL_SECRET=change-me-in-production
